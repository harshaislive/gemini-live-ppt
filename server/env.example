# Required: Google Gemini Live key
GOOGLE_API_KEY=AIza...

# Required: either set DAILY_API_KEY for dynamic rooms,
# or DAILY_ROOM_URL if you want to reuse a fixed room locally.
DAILY_API_KEY=your_daily_api_key
# DAILY_ROOM_URL=https://yourdomain.daily.co/yourroom

# Optional runtime settings
GEMINI_LIVE_MODEL=gemini-2.5-flash-native-audio-preview-12-2025
GOOGLE_VOICE_ID=Charon
GOOGLE_LANGUAGE_CODE=en-US
ENV=local
